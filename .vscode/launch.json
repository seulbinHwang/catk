      "request": "launch",
      "program": "${workspaceFolder}/src/run.py",
      "python": "/home2/pnc2/miniforge3/envs/catk/bin/python",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
      "env": {
        "HYDRA_FULL_ERROR": "1",
